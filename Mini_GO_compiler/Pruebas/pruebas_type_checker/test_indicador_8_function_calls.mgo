// PRUEBA - Indicador 8: Validación de parámetros en llamadas a funciones
/*No compilar y correr, podria contener limitaciones que provocaran un error en el encoder, compilar 
y correr en Pruebas/mgo/pruebas_de_Encoder en su lugar
*/

package main;

func add(a int, b int) int {
	return a + b;
};

func concatenate(s1 string, s2 string) string {
	return s1 + s2;
};

func noParams() {
	println("No parameters");
};

func multipleParams(x int, y float64, z string, w bool) string {
	return "test";
};

func testFunctionCallsCorrect() {
	// Llamadas válidas
	var result1 int = add(5, 3);           // OK: 2 parámetros int
	var result2 string = concatenate("hello", "world");  // OK: 2 parámetros string
	noParams();                            // OK: sin parámetros
	var result3 string = multipleParams(10, 3.14, "test", true);  // OK: todos los tipos correctos

	println(result1);
	println(result2);
	println(result3);
};

func testFunctionCallsErrors() {

	// Error: número incorrecto de parámetros
	//var x int = add(5);                    // ERROR: faltan parámetros (esperados 2, dados 1)
	//var y int = add(1, 2, 3);              // ERROR: demasiados parámetros (esperados 2, dados 3)
	//var z string = concatenate("only");    // ERROR: faltan parámetros
	//noParams(10);                          // ERROR: demasiados parámetros (esperados 0, dado 1)

	// Error: tipo incorrecto de parámetros
	//var a int = add("hello", "world");     // ERROR: se esperan int, se dan string
	//var b int = add(3.14, 2.71);           // ERROR: se esperan int, se dan float64
	//var c string = concatenate(10, 20);    // ERROR: se esperan string, se dan int

	// Error: mezcla de tipos correctos e incorrectos
	//var e int = add(5, "text");            // ERROR: segundo parámetro tipo incorrecto
	//var f string = concatenate("hello", 42); // ERROR: segundo parámetro tipo incorrecto
};

func sum3(a int, b int, c int) int {
	return a + b + c;
};

func testMultipleParamsSameType() {
	var x int = sum3(1, 2, 3);  // OK

	// ERRORES detectados:
	//var y int = sum3(1, 2);     // ERROR: faltan parámetros
	//var z int = sum3(1, "two", 3); // ERROR: segundo parámetro tipo incorrecto
};
