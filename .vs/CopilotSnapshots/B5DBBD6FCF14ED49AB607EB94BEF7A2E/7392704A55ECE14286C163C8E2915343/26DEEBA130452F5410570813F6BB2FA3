<?xml version="1.0" encoding="utf-8"?>
<SyntaxDefinition name="Mini Go" extensions=".go;.mgo" xmlns="http://icsharpcode.net/sharpdevelop/syntaxdefinition/2008">
    <!-- Colores -->
    <Color name="Keyword" foreground="Blue" fontWeight="bold" />
    <Color name="Comment" foreground="Green" />
    <Color name="String" foreground="Red" />
    <Color name="RawString" foreground="Red" />
    <Color name="Number" foreground="DarkGreen" />
    <Color name="Float" foreground="DarkGreen" />
    <Color name="Rune" foreground="DarkGreen" />

    <RuleSet>
        <!-- Palabras clave -->
        <Keywords color="Keyword">
            <Word>package</Word>
            <Word>var</Word>
            <Word>type</Word>
            <Word>func</Word>
            <Word>return</Word>
            <Word>if</Word>
            <Word>else</Word>
            <Word>for</Word>
            <Word>switch</Word>
            <Word>case</Word>
            <Word>default</Word>
            <Word>break</Word>
            <Word>continue</Word>
            <Word>print</Word>
            <Word>println</Word>
            <Word>len</Word>
            <Word>cap</Word>
            <Word>append</Word>
            <Word>struct</Word>
        </Keywords>

        <!-- Comentarios // -->
        <Span color="Comment">
            <Begin>//</Begin>
        </Span>

        <!-- Comentarios /* ... */ -->
        <Span color="Comment" multiline="true">
            <Begin>/\*</Begin>
            <End>\*/</End>
        </Span>

        <!-- Cadenas raw `...` -->
        <Span color="RawString" multiline="true">
            <Begin>`</Begin>
            <End>`</End>
        </Span>

        <!-- Cadenas interpretadas "..." -->
        <Span color="String">
            <Begin>"</Begin>
            <End>"</End>
        </Span>

        <!-- Rune 'a' -->
        <Span color="Rune">
            <Begin>'</Begin>
            <End>'</End>
        </Span>

        <!-- Números -->
        <Rule color="Number">
            \b0[xX][0-9a-fA-F]+  # hex number
            |    \b
            (    \d+(\.[0-9]+)?   # number with optional floating point
            |    \.[0-9]+         # or just starting with floating point
            )
            ([eE][+-]?[0-9]+)?    # optional exponent
        </Rule>
    </RuleSet>
</SyntaxDefinition>
