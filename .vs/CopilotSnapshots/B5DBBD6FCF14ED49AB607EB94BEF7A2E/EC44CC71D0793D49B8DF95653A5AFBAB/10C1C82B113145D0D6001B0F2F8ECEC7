<?xml version="1.0" encoding="utf-8"?>
<SyntaxDefinition name="Mini Go" xmlns="http://icsharpcode.net/sharpdevelop/syntaxdefinition/2023">
    <!-- Colores -->
    <Color name="Keyword" foreground="#0000FF" fontWeight="bold" />
    <Color name="Comment" foreground="#008000" />
    <Color name="String" foreground="#A31515" />
    <Color name="RawString" foreground="#A31515" />
    <Color name="Number" foreground="#098658" />
    <Color name="Float" foreground="#098658" />
    <Color name="Rune" foreground="#098658" />
    <Color name="Operator" foreground="#000000" />
    <Color name="Identifier" foreground="#000000" />

    <RuleSet>
        <!-- Palabras clave -->
        <Span color="Keyword">
            <Begin>\b(package|var|type|func|return|if|else|for|switch|case|default|break|continue|print|println|len|cap|append|struct)\b</Begin>
        </Span>

        <!-- Comentarios // -->
        <Span color="Comment">
            <Begin>//</Begin>
            <End>$</End>
        </Span>

        <!-- Comentarios /* ... */ -->
        <Span color="Comment" multiline="true">
            <Begin>/\*</Begin>
            <End>\*/</End>
        </Span>

        <!-- Cadenas raw `...` -->
        <Span color="RawString" multiline="true">
            <Begin>`</Begin>
            <End>`</End>
        </Span>

        <!-- Cadenas interpretadas "..." -->
        <Span color="String" multiline="false">
            <Begin>"</Begin>
            <End>"</End>
        </Span>

        <!-- Rune 'a' -->
        <Span color="Rune" multiline="false">
            <Begin>'</Begin>
            <End>'</End>
        </Span>

        <!-- Números enteros -->
        <Rule color="Number">\b[0-9]+\b</Rule>

        <!-- Números flotantes -->
        <Rule color="Float">\b[0-9]+\.[0-9]+\b</Rule>

        <!-- Operadores multi-carácter -->
        <Rule color="Operator">
            (==|!=|&lt;=|&gt;=|&amp;&amp;|\|\||&lt;&lt;|&gt;&gt;|&amp;\^|\+=|-=|\*=|/=|%=|&amp;=|\|=|\^=|&lt;&lt;=|&gt;&gt;=|&amp;\^=|\+\+|\-\-|:=)
        </Rule>

        <!-- Operadores de un solo carácter -->
        <Rule color="Operator">[=!&lt;&gt;+\-*/%&amp;|^~?:;,.(){}\[\]]</Rule>

        <!-- Identificadores -->
        <Rule color="Identifier">\b[a-zA-Z_][a-zA-Z0-9_]*\b</Rule>
    </RuleSet>
</SyntaxDefinition>
