using SyntaxChecker.generated;
using LLVMSharp.Interop;
using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using static LLVMSharp.Interop.LLVM;

namespace Mini_GO_compiler.Encoder;

public class EncoderVisitor : MiniGoCompilerBaseVisitor<object>
{
    // LLVM core components
    private LLVMModuleRef module;
    private LLVMBuilderRef builder;

    // LLVM types
    private readonly LLVMTypeRef int32Type;
    private readonly LLVMTypeRef int64Type;
    private readonly LLVMTypeRef doubleType;
    private readonly LLVMTypeRef boolType;
    private readonly LLVMTypeRef voidType;
    private readonly LLVMTypeRef stringPtrType;

    // Symbol tables
    private readonly Dictionary<string, LLVMValueRef> functions;
    private readonly Dictionary<string, LLVMTypeRef> functionTypes;
    private readonly Stack<Dictionary<string, VariableInfo>> variableScopes;

    // State tracking
    private LLVMValueRef currentFunction;
    private string outputDirectory;
    private int globalStringCounter;

    // Variable information holder
    private class VariableInfo
    {
        public LLVMValueRef Alloca { get; set; }
        public LLVMTypeRef Type { get; set; }

        public VariableInfo(LLVMValueRef alloca, LLVMTypeRef type)
        {
            Alloca = alloca;
            Type = type;
        }
    }

    public EncoderVisitor(string outputDir = null)
    {
        this.outputDirectory = outputDir ?? Path.Combine("target", "minigo-output");

        // Initialize LLVM types
        this.int32Type = LLVMTypeRef.CreateInt32();
        this.int64Type = LLVMTypeRef.CreateInt64();
        this.doubleType = LLVMTypeRef.CreateDouble();
        this.boolType = LLVMTypeRef.CreateInt1();
        this.voidType = LLVMTypeRef.CreateVoid();
        this.stringPtrType = LLVMTypeRef.CreatePointer(LLVMTypeRef.CreateInt8(), 0);

        // Initialize symbol tables
        this.functions = new Dictionary<string, LLVMValueRef>();
        this.functionTypes = new Dictionary<string, LLVMTypeRef>();
        this.variableScopes = new Stack<Dictionary<string, VariableInfo>>();

        this.globalStringCounter = 0;
    }

    public string GeneratedLlPath { get; private set; }
    public string GeneratedExePath { get; private set; }

    // ========== VISITOR METHODS ==========

    public override object VisitRoot(MiniGoCompilerParser.RootContext context)
    {
        // Initialize LLVM
        InitializeLLVM();

        // Create module and builder
        this.module = LLVMModuleRef.CreateWithName("minigo_module");
        this.builder = module.Context.CreateBuilder();

        // Clear state
        this.functions.Clear();
        this.functionTypes.Clear();
        this.variableScopes.Clear();
        this.globalStringCounter = 0;

        // Visit all top-level declarations
        if (context.topDeclarationList() != null)
        {
            Visit(context.topDeclarationList());
        }

        // Generate output files
        GenerateOutput();

        // Cleanup
        builder.Dispose();
        module.Dispose();

        return null;
    }

    private void InitializeLLVM()
    {
        LLVM.LinkInMCJIT();
        LLVM.InitializeX86TargetInfo();
        LLVM.InitializeX86Target();
        LLVM.InitializeX86TargetMC();
        LLVM.InitializeX86AsmParser();
        LLVM.InitializeX86AsmPrinter();
    }

    private void GenerateOutput()
    {
        try
        {
            // Create output directory
            Directory.CreateDirectory(outputDirectory);

            // Write LLVM IR to file
            string llContent = module.PrintToString();
            GeneratedLlPath = Path.Combine(outputDirectory, "program.ll");
            File.WriteAllText(GeneratedLlPath, llContent);

            Console.WriteLine($"LLVM IR generated: {GeneratedLlPath}");
            Console.WriteLine(llContent);

            // Try to compile with clang if available
            GeneratedExePath = Path.Combine(outputDirectory, "program.exe");
            TryCompileWithClang(GeneratedLlPath, GeneratedExePath);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating output: {ex.Message}");
        }
    }

    private void TryCompileWithClang(string llPath, string exePath)
    {
        try
        {
            var process = new System.Diagnostics.Process
            {
                StartInfo = new System.Diagnostics.ProcessStartInfo
                {
                    FileName = "clang",
                    Arguments = $"\"{llPath}\" -o \"{exePath}\"",
                    RedirectStandardOutput = true,
                    RedirectStandardError = true,
                    UseShellExecute = false,
                    CreateNoWindow = true
                }
            };

            process.Start();
            string output = process.StandardOutput.ReadToEnd();
            string error = process.StandardError.ReadToEnd();
            process.WaitForExit();

            if (process.ExitCode == 0)
            {
                Console.WriteLine($"Executable generated: {exePath}");
            }
            else
            {
                Console.WriteLine($"Clang compilation failed: {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Clang not available: {ex.Message}");
        }
    }

    public override object VisitTopDeclarationList(MiniGoCompilerParser.TopDeclarationListContext context)
    {
        // Visit all top-level declarations in order
        foreach (var varDecl in context.variableDecl())
        {
            Visit(varDecl);
        }

        foreach (var funcDecl in context.funcDecl())
        {
            Visit(funcDecl);
        }

        return null;
    }
}