<Window x:Class="Mini_GO_compiler.View.UserControls.InputFileMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mini_GO_compiler.View.UserControls"
        mc:Ignorable="d"
        Title="InputFileMessageBox" Height="155" Width="250"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Name="InputMessage" Text="Insert file name" HorizontalAlignment="Center"></TextBlock>
        <TextBox Grid.Row="1" Name="txtInput" Margin="0,0,0,15" Padding="3"/>
        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Name="btnOk" Content="OK" Width="75" IsDefault="True" Click="BtnOk_Click"/>
            <Button Content="Cancel" Width="75" IsCancel="True" Margin="55,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
