using SyntaxChecker.generated;
using LLVMSharp.Interop;
using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Runtime.InteropServices;

namespace Mini_GO_compiler.Encoder;

public class EncoderVisitor : MiniGoCompilerBaseVisitor<object>
{
    private LLVMModuleRef module;
    private LLVMBuilderRef builder;

    // Tipos LLVM basicos
    private LLVMTypeRef int32Type;
    private LLVMTypeRef voidType;

    // Tabla de variables (nombre -> LLVMValueRef)
    private readonly Stack<Dictionary<string, LLVMValueRef>> scopes;

    // Tabla de tipos de variables (nombre -> LLVMTypeRef del tipo subyacente)
    private readonly Stack<Dictionary<string, LLVMTypeRef>> typeScopes;

    // Tabla de funciones definidas por el usuario
    private readonly Dictionary<string, LLVMValueRef> functions;

    // Tabla de tipos de funciones (nombre -> LLVMTypeRef del tipo de función)
    private readonly Dictionary<string, LLVMTypeRef> functionTypes;

    // Funcion actual
    private LLVMValueRef currentFunction;

    // Funciones predefinidas
    private LLVMValueRef printfFunc;
    private LLVMTypeRef printfType;
    private LLVMValueRef fflushFunc;
    private LLVMTypeRef fflushType;

    // Punteros a funciones del sistema (para JIT)
    private static IntPtr printfPtr;
    private static IntPtr fflushPtr;

    // Flag para indicar si necesitamos un lvalue (puntero) o rvalue (valor)
    private bool needsLValue = false;

    public EncoderVisitor()
    {
        //this.int32Type = LLVMTypeRef.Int32;
        //this.voidType = LLVMTypeRef.Void;
        this.scopes = new Stack<Dictionary<string, LLVMValueRef>>();
        this.typeScopes = new Stack<Dictionary<string, LLVMTypeRef>>();
        this.functions = new Dictionary<string, LLVMValueRef>();
        this.functionTypes = new Dictionary<string, LLVMTypeRef>();
    }

    // ===== IMPORTACIONES PARA JIT =====

    [DllImport("kernel32.dll", CharSet = CharSet.Unicode, SetLastError = true)]
    private static extern IntPtr LoadLibrary(string lpFileName);

    [DllImport("kernel32.dll", CharSet = CharSet.Ansi, SetLastError = true)]
    private static extern IntPtr GetProcAddress(IntPtr hModule, string lpProcName);

    private static void InitializePrintf()
    {
        if (printfPtr != IntPtr.Zero)
            return; // Ya inicializado

        IntPtr msvcrt = LoadLibrary("msvcrt.dll");
        if (msvcrt == IntPtr.Zero)
        {
            throw new Exception("No se pudo cargar msvcrt.dll");
        }

        printfPtr = GetProcAddress(msvcrt, "printf");
        if (printfPtr == IntPtr.Zero)
        {
            throw new Exception("No se pudo obtener el símbolo printf");
        }

        fflushPtr = GetProcAddress(msvcrt, "fflush");
        if (fflushPtr == IntPtr.Zero)
        {
            throw new Exception("No se pudo obtener el símbolo fflush");
        }

        Console.WriteLine($"✅ printf cargado desde msvcrt.dll: 0x{printfPtr:X}");
        Console.WriteLine($"✅ fflush cargado desde msvcrt.dll: 0x{fflushPtr:X}");
    }

    public string GeneratedIR { get; private set; }

    public override object VisitRoot(MiniGoCompilerParser.RootContext context)
    {
        // Inicializar LLVM
        LLVM.InitializeX86TargetInfo();
        LLVM.InitializeX86Target();
        LLVM.InitializeX86TargetMC();
        LLVM.InitializeX86AsmPrinter();
        LLVM.InitializeX86AsmParser();

        // Vincular MCJIT para ejecución
        LLVM.LinkInMCJIT();

        // Crear m�dulo y builder
        module = LLVMModuleRef.CreateWithName("minigo_module");
        builder = module.Context.CreateBuilder();

        // Inicializar tipos LLVM ahora que el contexto esta listo
        this.int32Type = LLVMTypeRef.Int32;
        this.voidType = LLVMTypeRef.Void;

        // Declarar funciones predefinidas
        DeclarePredefinedFunctions();
        
        // Visitar declaraciones
        if (context.topDeclarationList() != null)
        {
            Visit(context.topDeclarationList());
        }

        // Generar IR
        GeneratedIR = module.PrintToString();
        Console.WriteLine("=== LLVM IR Generated ===");
        Console.WriteLine(GeneratedIR);

        // Guardar a archivo
        try
        {
            string outputDir = Path.Combine("target", "minigo-output");
            Directory.CreateDirectory(outputDir);
            string outputPath = Path.Combine(outputDir, "program.ll");
            File.WriteAllText(outputPath, GeneratedIR);
            Console.WriteLine($"\nIR saved to: {outputPath}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving IR: {ex.Message}");
        }

        var result = createExcutionEngine();
        builder.Dispose();
        module.Dispose();

        return null;
    }

    //Función auxiliar para crear un execution engine (LinkInMCJIT)
    public LLVMGenericValueRef createExcutionEngine()
    {
        if(module.TryVerify(LLVMVerifierFailureAction.LLVMPrintMessageAction, out string error))
        {
            // Inicializar printf
            InitializePrintf();

            // Opciones para MCJIT
            var options = new LLVMMCJITCompilerOptions { NoFramePointerElim = 1 };
            options.OptLevel = 0; // Sin optimizaciones para debuggear

            if (module.TryCreateMCJITCompiler(out LLVMExecutionEngineRef engine, ref options, out string engineError))
            {
                // Mapear los símbolos printf y fflush al puntero de la DLL
                engine.AddGlobalMapping(printfFunc, printfPtr);
                engine.AddGlobalMapping(fflushFunc, fflushPtr);

                // Buscar main
                if (functions.ContainsKey("main"))
                {
                    LLVMValueRef mainFunc = functions["main"];

                    Console.WriteLine("=== Ejecutando programa via JIT ===");

                    // Ejecutar (esto depende de si main tiene parámetros o no)
                    // Para main() sin parámetros:
                    var result = engine.RunFunction(mainFunc, Array.Empty<LLVMGenericValueRef>());

                    Console.WriteLine("=== Programa ejecutado con éxito ===");

                    // No disponer engine todavía si se necesita mantener el módulo vivo
                    // engine.Dispose();

                    return result;
                }
                else
                {
                    Console.WriteLine("⚠️ No se encontró la función 'main' para ejecutar");
                }
            }
            else
            {
                Console.WriteLine($"❌ Error creating engine: {engineError}");
            }
        }
        else
        {
            Console.WriteLine($"❌ Module verification failed: {error}");   
        }
        return null;
    }
    
    
    private void DeclarePredefinedFunctions()
    {
        // Declarar printf de C (para implementar print y println)
        // int printf(char* format, ...)
        LLVMTypeRef charPtr = LLVMTypeRef.CreatePointer(LLVMTypeRef.Int8, 0);
        printfType = LLVMTypeRef.CreateFunction(int32Type, new[] { charPtr }, true); // true = variadic
        printfFunc = module.AddFunction("printf", printfType);

        // Declarar fflush de C (para forzar flush del buffer)
        // int fflush(FILE* stream) - NULL para flush de todos los buffers
        fflushType = LLVMTypeRef.CreateFunction(int32Type, new[] { charPtr }, false);
        fflushFunc = module.AddFunction("fflush", fflushType);
    }

    public override object VisitTopDeclarationList(MiniGoCompilerParser.TopDeclarationListContext context)
    {
        // Procesar variables globales
        foreach (var varDecl in context.variableDecl())
        {
            Visit(varDecl);
        }

        // Procesar funciones
        foreach (var funcDecl in context.funcDecl())
        {
            Visit(funcDecl);
        }

        return null;
    }

    // ===== FUNCIONES =====

    public override object VisitFuncDecl(MiniGoCompilerParser.FuncDeclContext context)
    {
        Visit(context.funcFrontDecl());

        // Procesar el bloque de la función
        if (context.block() != null)
        {
            Visit(context.block());
        }

        // Finalizar la función
        // Si no hay un return explícito al final, agregar uno
        if (currentFunction.Handle != IntPtr.Zero)
        {
            var lastBlock = currentFunction.LastBasicBlock;
            if (lastBlock.Handle != IntPtr.Zero)
            {
                var terminator = lastBlock.Terminator;
                if (terminator.Handle == IntPtr.Zero)
                {
                    // No hay terminador, agregar return void
                    builder.BuildRetVoid();
                }
            }
        }

        // Salir del scope de la función
        scopes.Pop();
        typeScopes.Pop();
        currentFunction = default;

        return null;
    }

    public override object VisitFuncFrontDecl(MiniGoCompilerParser.FuncFrontDeclContext context)
    {
        string funcName = context.IDENTIFIER().GetText();

        // Tipo de retorno
        LLVMTypeRef returnType = voidType;
        if (context.declType() != null)
        {
            returnType = GetLLVMType(context.declType());
        }

        // Parámetros
        LLVMTypeRef[] paramTypes = Array.Empty<LLVMTypeRef>();
        if (context.funcArgDecls() != null)
        {
            var argDecls = context.funcArgDecls().singleVarDeclNoExps();
            paramTypes = new LLVMTypeRef[argDecls.Length];
            for (int i = 0; i < argDecls.Length; i++)
            {
                paramTypes[i] = GetLLVMType(argDecls[i].declType());
            }
        }

        // Crear el tipo de función
        LLVMTypeRef funcType = LLVMTypeRef.CreateFunction(returnType, paramTypes);

        // Agregar la función al módulo
        currentFunction = module.AddFunction(funcName, funcType);

        // Guardar en el diccionario de funciones
        functions[funcName] = currentFunction;
        functionTypes[funcName] = funcType;

        // Crear el bloque de entrada
        LLVMBasicBlockRef entryBlock = currentFunction.AppendBasicBlock("entry");
        builder.PositionAtEnd(entryBlock);

        // Crear un nuevo scope para la función
        scopes.Push(new Dictionary<string, LLVMValueRef>());
        typeScopes.Push(new Dictionary<string, LLVMTypeRef>());

        // Si hay parámetros, agregarlos a la tabla de símbolos
        if (context.funcArgDecls() != null)
        {
            var argDecls = context.funcArgDecls().singleVarDeclNoExps();
            for (int i = 0; i < argDecls.Length; i++)
            {
                string paramName = argDecls[i].identifierList().IDENTIFIER(0).GetText();
                LLVMValueRef param = currentFunction.GetParam((uint)i);
                param.Name = paramName;

                // Obtener el tipo del parámetro
                LLVMTypeRef paramType = paramTypes[i];

                // Crear una alloca para el parámetro
                LLVMValueRef alloca = builder.BuildAlloca(paramType, paramName);
                builder.BuildStore(param, alloca);

                // Agregar a la tabla de símbolos
                scopes.Peek()[paramName] = alloca;
                typeScopes.Peek()[paramName] = paramType;
            }
        }

        return null;
    }

    public override object VisitBlock(MiniGoCompilerParser.BlockContext context)
    {
        if (context.statementList() != null)
        {
            Visit(context.statementList());
        }
        return null;
    }

    public override object VisitStatementList(MiniGoCompilerParser.StatementListContext context)
    {
        foreach (var statement in context.statement())
        {
            Visit(statement);
        }
        return null;
    }

    public override object VisitStatement(MiniGoCompilerParser.StatementContext context)
    {
        // Declaración de variable
        if (context.variableDecl() != null)
        {
            Visit(context.variableDecl());
        }
        // Statement simple (asignación, expresión)
        else if (context.simpleStatement() != null)
        {
            Visit(context.simpleStatement());
        }
        // Print statement
        else if (context.PRINT() != null)
        {
            List<LLVMValueRef> args = new List<LLVMValueRef>();
            if (context.expressionList() != null)
            {
                foreach (var expr in context.expressionList().expression())
                {
                    var argValue = Visit(expr) as LLVMValueRef?;
                    if (argValue.HasValue)
                    {
                        args.Add(argValue.Value);
                    }
                }
            }
            BuildPrintCall(args, false);
        }
        // Println statement
        else if (context.PRINTLN() != null)
        {
            List<LLVMValueRef> args = new List<LLVMValueRef>();
            if (context.expressionList() != null)
            {
                foreach (var expr in context.expressionList().expression())
                {
                    var argValue = Visit(expr) as LLVMValueRef?;
                    if (argValue.HasValue)
                    {
                        args.Add(argValue.Value);
                    }
                }
            }
            BuildPrintCall(args, true);
        }
        // Return
        else if (context.RETURN() != null)
        {
            if (context.expression() != null)
            {
                var returnValue = Visit(context.expression()) as LLVMValueRef?;
                if (returnValue.HasValue)
                {
                    builder.BuildRet(returnValue.Value);
                }
            }
            else
            {
                builder.BuildRetVoid();
            }
        }
        // Block
        else if (context.block() != null)
        {
            scopes.Push(new Dictionary<string, LLVMValueRef>());
            typeScopes.Push(new Dictionary<string, LLVMTypeRef>());
            Visit(context.block());
            scopes.Pop();
            typeScopes.Pop();
        }
        // If Statement
        else if (context.ifStatement() != null)
        {
            Visit(context.ifStatement());
        }
        // Loop
        else if (context.loop() != null)
        {
            Visit(context.loop());
        }

        return null;
    }

    public override object VisitVariableDecl(MiniGoCompilerParser.VariableDeclContext context)
    {
        if (context.singleVarDecl() != null)
        {
            Visit(context.singleVarDecl());
        }
        else if (context.innerVarDecls() != null)
        {
            foreach (var singleDecl in context.innerVarDecls().singleVarDecl())
            {
                Visit(singleDecl);
            }
        }
        return null;
    }

    public override object VisitSingleVarDecl(MiniGoCompilerParser.SingleVarDeclContext context)
    {
        // Manejo de declaraciones sin inicialización: var x int  o  var arr [10]int
        if (context.singleVarDeclNoExps() != null)
        {
            Visit(context.singleVarDeclNoExps());
        }
        // Manejo de declaraciones con inicialización: var x int = 1
        else if (context.declType() != null && context.expressionList() != null)
        {
            var identifiers = context.identifierList().IDENTIFIER();
            var declType = context.declType();
            var expressions = context.expressionList().expression();

            if (identifiers.Length != expressions.Length)
            {
                throw new Exception("Mismatch between identifiers and expressions count");
            }

            for (int i = 0; i < identifiers.Length; i++)
            {
                string varName = identifiers[i].GetText();
                LLVMTypeRef type = GetLLVMType(declType);

                // Determinar si es global o local
                bool isGlobal = currentFunction.Handle == IntPtr.Zero;

                LLVMValueRef varRef;
                if (isGlobal)
                {
                    // Variable global con inicializador
                    varRef = module.AddGlobal(type, varName);

                    // Evaluar la expresión de inicialización (debe ser constante para globales)
                    var initValue = Visit(expressions[i]) as LLVMValueRef?;
                    if (initValue.HasValue)
                    {
                        varRef.Initializer = initValue.Value;
                    }
                    else
                    {
                        varRef.Initializer = GetZeroInitializer(type);
                    }
                }
                else
                {
                    // Variable local (alloca)
                    varRef = builder.BuildAlloca(type, varName);

                    // Evaluar la expresión de inicialización y almacenarla
                    var initValue = Visit(expressions[i]) as LLVMValueRef?;
                    if (initValue.HasValue)
                    {
                        builder.BuildStore(initValue.Value, varRef);
                    }
                }

                // Guardar en la tabla de símbolos
                if (scopes.Count > 0)
                {
                    scopes.Peek()[varName] = varRef;
                    typeScopes.Peek()[varName] = type;
                }
                else
                {
                    var globalScope = new Dictionary<string, LLVMValueRef>();
                    globalScope[varName] = varRef;
                    scopes.Push(globalScope);

                    var globalTypeScope = new Dictionary<string, LLVMTypeRef>();
                    globalTypeScope[varName] = type;
                    typeScopes.Push(globalTypeScope);
                }
            }
        }
        return null;
    }

    public override object VisitSingleVarDeclNoExps(MiniGoCompilerParser.SingleVarDeclNoExpsContext context)
    {
        var identifiers = context.identifierList().IDENTIFIER();
        var declType = context.declType();

        foreach (var id in identifiers)
        {
            string varName = id.GetText();
            LLVMTypeRef type = GetLLVMType(declType);

            // Determinar si es global o local
            bool isGlobal = currentFunction.Handle == IntPtr.Zero;

            LLVMValueRef varRef;
            if (isGlobal)
            {
                // Variable global
                varRef = module.AddGlobal(type, varName);
                varRef.Initializer = GetZeroInitializer(type);
            }
            else
            {
                // Variable local (alloca)
                varRef = builder.BuildAlloca(type, varName);
            }

            // Guardar en la tabla de s�mbolos
            if (scopes.Count > 0)
            {
                scopes.Peek()[varName] = varRef;
                typeScopes.Peek()[varName] = type;
            }
            else
            {
                var globalScope = new Dictionary<string, LLVMValueRef>();
                globalScope[varName] = varRef;
                scopes.Push(globalScope);

                var globalTypeScope = new Dictionary<string, LLVMTypeRef>();
                globalTypeScope[varName] = type;
                typeScopes.Push(globalTypeScope);
            }
        }

        return null;
    }

    private LLVMTypeRef GetLLVMType(MiniGoCompilerParser.DeclTypeContext context)
    {
        // Tipo simple: int
        if (context.IDENTIFIER() != null)
        {
            string typeName = context.IDENTIFIER().GetText();
            if (typeName == "int")
            {
                return int32Type;
            }
            throw new Exception($"Type not supported: {typeName}");
        }

        // Array: [N]int
        if (context.arrayDeclType() != null)
        {
            var arrayCtx = context.arrayDeclType();
            int size = int.Parse(arrayCtx.INTLITERAL().GetText());

            // Verificar que el tipo elemento sea int
            var elemType = GetLLVMType(arrayCtx.declType());
            if (elemType.Handle != int32Type.Handle)
            {
                throw new Exception("Only int arrays supported");
            }

            return LLVMTypeRef.CreateArray(elemType, (uint)size);
        }

        throw new Exception("Unsupported type declaration");
    }

    private LLVMValueRef GetZeroInitializer(LLVMTypeRef type)
    {
        if (type.Kind == LLVMTypeKind.LLVMIntegerTypeKind)
        {
            return LLVMValueRef.CreateConstInt(type, 0, false);
        }
        else if (type.Kind == LLVMTypeKind.LLVMArrayTypeKind)
        {
            // Array de ceros
            uint arraySize = type.ArrayLength;
            LLVMValueRef[] zeros = new LLVMValueRef[arraySize];
            for (uint i = 0; i < arraySize; i++)
            {
                zeros[i] = GetZeroInitializer(type.ElementType);
            }
            return LLVMValueRef.CreateConstArray(type.ElementType, zeros);
        }

        return LLVMValueRef.CreateConstInt(int32Type, 0, false);
    }

    private LLVMValueRef ResolveVariable(string name)
    {
        foreach (var scope in scopes)
        {
            if (scope.ContainsKey(name))
            {
                return scope[name];
            }
        }
        throw new Exception($"Variable not found: {name}");
    }

    private LLVMTypeRef ResolveVariableType(string name)
    {
        foreach (var typeScope in typeScopes)
        {
            if (typeScope.ContainsKey(name))
            {
                return typeScope[name];
            }
        }
        throw new Exception($"Variable type not found: {name}");
    }

    // ===== EXPRESIONES =====

    public override object VisitExpression(MiniGoCompilerParser.ExpressionContext context)
    {
        // Expresión primaria simple
        if (context.primaryExpression() != null && context.ChildCount == 1)
        {
            return Visit(context.primaryExpression());
        }

        // Operadores binarios
        if (context.ChildCount == 3)
        {
            var left = Visit(context.expression(0)) as LLVMValueRef?;
            var right = Visit(context.expression(1)) as LLVMValueRef?;

            if (!left.HasValue || !right.HasValue)
            {
                throw new Exception("Invalid operands in binary expression");
            }

            string op = context.GetChild(1).GetText();
            return BuildBinaryOp(left.Value, right.Value, op);
        }

        // Operadores unarios: +expr, -expr, !expr, ^expr
        if (context.ChildCount == 2)
        {
            var operand = Visit(context.expression(0)) as LLVMValueRef?;
            if (!operand.HasValue)
            {
                throw new Exception("Invalid operand in unary expression");
            }

            string op = context.GetChild(0).GetText();
            return BuildUnaryOp(operand.Value, op);
        }

        throw new Exception("Unsupported expression form");
    }

    public override object VisitPrimaryExpression(MiniGoCompilerParser.PrimaryExpressionContext context)
    {
        // Operando simple (literal o identificador)
        if (context.operand() != null)
        {
            return Visit(context.operand());
        }

        // Indexación de array: arr[index]
        if (context.index() != null)
        {
            var baseExpr = Visit(context.primaryExpression()) as LLVMValueRef?;
            var indexExpr = Visit(context.index().expression()) as LLVMValueRef?;

            if (!baseExpr.HasValue || !indexExpr.HasValue)
            {
                throw new Exception("Invalid array indexing");
            }

            // Obtener el nombre de la variable base para extraer su tipo
            string baseVarName = GetBaseVariableName(context.primaryExpression());
            LLVMTypeRef baseType = ResolveVariableType(baseVarName);

            // baseExpr es un puntero al array (alloca o global)
            // Necesitamos hacer un GEP para acceder al elemento
            LLVMValueRef[] indices = new LLVMValueRef[]
            {
                LLVMValueRef.CreateConstInt(int32Type, 0, false), // Índice del array (siempre 0 para primer nivel)
                indexExpr.Value // Índice del elemento
            };

            LLVMValueRef elemPtr = builder.BuildGEP2(
                baseType,
                baseExpr.Value,
                indices,
                "arrayidx"
            );

            // Si no necesitamos un lvalue (puntero), cargar el valor
            if (!needsLValue)
            {
                // Los arrays son siempre de int32 por ahora
                return builder.BuildLoad2(int32Type, elemPtr, "arrayval");
            }

            return elemPtr;
        }

        // Llamada a función: func(args)
        if (context.arguments() != null)
        {
            return VisitFunctionCall(context);
        }

        // Length expression: len(arr)
        if (context.lengthExpression() != null)
        {
            return VisitLengthExpression(context.lengthExpression());
        }

        throw new Exception("Unsupported primary expression");
    }

    private string GetBaseVariableName(MiniGoCompilerParser.PrimaryExpressionContext context)
    {
        // Si es un operando con identificador, devolver el nombre
        if (context.operand() != null && context.operand().identifier() != null)
        {
            return context.operand().identifier().GetText();
        }

        // Si es una indexación recursiva, obtener el nombre base
        if (context.primaryExpression() != null)
        {
            return GetBaseVariableName(context.primaryExpression());
        }

        throw new Exception("Cannot extract base variable name");
    }

    public override object VisitOperand(MiniGoCompilerParser.OperandContext context)
    {
        // Literal
        if (context.literal() != null)
        {
            return Visit(context.literal());
        }

        // Identificador (acceso a variable)
        if (context.identifier() != null)
        {
            string varName = context.identifier().GetText();
            LLVMValueRef varPtr = ResolveVariable(varName);
            LLVMTypeRef varType = ResolveVariableType(varName);

            // Si es un array, devolver el puntero directamente (para indexación)
            if (varType.Kind == LLVMTypeKind.LLVMArrayTypeKind)
            {
                return varPtr;
            }

            // Para variables simples, cargar el valor
            return builder.BuildLoad2(varType, varPtr, varName);
        }

        // Expresión entre paréntesis
        if (context.expression() != null)
        {
            return Visit(context.expression());
        }

        throw new Exception("Unsupported operand");
    }

    public override object VisitLiteral(MiniGoCompilerParser.LiteralContext context)
    {
        // Literal entero
        if (context.INTLITERAL() != null)
        {
            string text = context.INTLITERAL().GetText();
            long value = long.Parse(text);
            return LLVMValueRef.CreateConstInt(int32Type, (ulong)value, true);
        }
        
        // Literal Raw String
        if (context.RAWSTRINGLITERAL() != null)
        {
            string rawStr = context.RAWSTRINGLITERAL().GetText();
            rawStr = rawStr.Substring(1, rawStr.Length - 2); // Quitar backticks
            return builder.BuildGlobalStringPtr(rawStr, "rawstr");
        }

        throw new Exception("Unsupported literal type");
    }

    // ===== ASIGNACIONES =====

    public override object VisitSimpleStatement(MiniGoCompilerParser.SimpleStatementContext context)
    {
        if (context.assignmentStatement() != null)
        {
            Visit(context.assignmentStatement());
        }
        else if (context.expression() != null)
        {
            // Expresión simple (ej: llamada a función o incremento/decremento)
            Visit(context.expression());
        }
        return null;
    }

    public override object VisitAssignmentStatement(MiniGoCompilerParser.AssignmentStatementContext context)
    {
        // Asignación simple: x = expr o arr[i] = expr
        if (context.ASSIGN() != null)
        {
            var leftExprs = context.expressionList(0).expression();
            var rightExprs = context.expressionList(1).expression();

            if (leftExprs.Length != rightExprs.Length)
            {
                throw new Exception("Mismatch in assignment count");
            }

            for (int i = 0; i < leftExprs.Length; i++)
            {
                var lhs = leftExprs[i];
                var rhs = rightExprs[i];

                // Evaluar el lado derecho
                var rhsValue = Visit(rhs) as LLVMValueRef?;
                if (!rhsValue.HasValue)
                {
                    throw new Exception("Invalid right-hand side in assignment");
                }

                // Determinar el destino (variable o elemento de array)
                LLVMValueRef destPtr;

                // Si es un identificador simple
                if (lhs.primaryExpression() != null && 
                    lhs.primaryExpression().operand() != null &&
                    lhs.primaryExpression().operand().identifier() != null)
                {
                    string varName = lhs.primaryExpression().operand().identifier().GetText();
                    destPtr = ResolveVariable(varName);
                }
                // Si es indexación de array: arr[i]
                else if (lhs.primaryExpression() != null && lhs.primaryExpression().index() != null)
                {
                    // Necesitamos el puntero (lvalue) para la asignación
                    try
                    {
                        needsLValue = true;
                        var elemPtr = Visit(lhs.primaryExpression()) as LLVMValueRef?;

                        if (!elemPtr.HasValue)
                        {
                            throw new Exception("Invalid array indexing in assignment");
                        }
                        destPtr = elemPtr.Value;
                    }
                    finally
                    {
                        needsLValue = false;
                    }
                }
                else
                {
                    throw new Exception("Unsupported left-hand side in assignment");
                }

                // Realizar el store
                builder.BuildStore(rhsValue.Value, destPtr);
            }
        }
        // Asignaciones compuestas: x += expr, x -= expr, etc.
        else if (context.ADDASSIGN() != null)
        {
            BuildCompoundAssignment(context.expression(0), context.expression(1), "add");
        }
        else if (context.SUBASSIGN() != null)
        {
            BuildCompoundAssignment(context.expression(0), context.expression(1), "sub");
        }
        else if (context.MULASSIGN() != null)
        {
            BuildCompoundAssignment(context.expression(0), context.expression(1), "mul");
        }
        else if (context.DIVASSIGN() != null)
        {
            BuildCompoundAssignment(context.expression(0), context.expression(1), "div");
        }

        return null;
    }

    private void BuildCompoundAssignment(MiniGoCompilerParser.ExpressionContext lhs, 
                                          MiniGoCompilerParser.ExpressionContext rhs, 
                                          string operation)
    {
        // Evaluar el lado derecho
        var rhsValue = Visit(rhs) as LLVMValueRef?;
        if (!rhsValue.HasValue)
        {
            throw new Exception("Invalid right-hand side in compound assignment");
        }

        // Obtener el puntero y cargar el valor actual
        LLVMValueRef destPtr;
        LLVMTypeRef destType;
        if (lhs.primaryExpression() != null &&
            lhs.primaryExpression().operand() != null &&
            lhs.primaryExpression().operand().identifier() != null)
        {
            string varName = lhs.primaryExpression().operand().identifier().GetText();
            destPtr = ResolveVariable(varName);
            destType = ResolveVariableType(varName);
        }
        else
        {
            throw new Exception("Unsupported left-hand side in compound assignment");
        }

        var currentValue = builder.BuildLoad2(destType, destPtr, "tmp");

        // Realizar la operación
        LLVMValueRef result;
        switch (operation)
        {
            case "add":
                result = builder.BuildAdd(currentValue, rhsValue.Value, "addtmp");
                break;
            case "sub":
                result = builder.BuildSub(currentValue, rhsValue.Value, "subtmp");
                break;
            case "mul":
                result = builder.BuildMul(currentValue, rhsValue.Value, "multmp");
                break;
            case "div":
                result = builder.BuildSDiv(currentValue, rhsValue.Value, "divtmp");
                break;
            default:
                throw new Exception($"Unsupported compound operation: {operation}");
        }

        // Almacenar el resultado
        builder.BuildStore(result, destPtr);
    }

    private LLVMValueRef BuildBinaryOp(LLVMValueRef left, LLVMValueRef right, string op)
    {
        switch (op)
        {
            case "+":
                return builder.BuildAdd(left, right, "addtmp");
            case "-":
                return builder.BuildSub(left, right, "subtmp");
            case "*":
                return builder.BuildMul(left, right, "multmp");
            case "/":
                return builder.BuildSDiv(left, right, "divtmp");
            case "%":
                return builder.BuildSRem(left, right, "modtmp");
            case "==":
                return builder.BuildICmp(LLVMIntPredicate.LLVMIntEQ, left, right, "eqtmp");
            case "!=":
                return builder.BuildICmp(LLVMIntPredicate.LLVMIntNE, left, right, "neqtmp");
            case "<":
                return builder.BuildICmp(LLVMIntPredicate.LLVMIntSLT, left, right, "lttmp");
            case "<=":
                return builder.BuildICmp(LLVMIntPredicate.LLVMIntSLE, left, right, "letmp");
            case ">":
                return builder.BuildICmp(LLVMIntPredicate.LLVMIntSGT, left, right, "gttmp");
            case ">=":
                return builder.BuildICmp(LLVMIntPredicate.LLVMIntSGE, left, right, "getmp");
            case "&":
                return builder.BuildAnd(left, right, "andtmp");
            case "|":
                return builder.BuildOr(left, right, "ortmp");
            case "^":
                return builder.BuildXor(left, right, "xortmp");
            default:
                throw new Exception($"Unsupported binary operator: {op}");
        }
    }

    private LLVMValueRef BuildUnaryOp(LLVMValueRef operand, string op)
    {
        switch (op)
        {
            case "+":
                return operand; // Unario + no hace nada
            case "-":
                return builder.BuildNeg(operand, "negtmp");
            case "!":
                return builder.BuildNot(operand, "nottmp");
            case "^":
                return builder.BuildNot(operand, "bitnottmp");
            default:
                throw new Exception($"Unsupported unary operator: {op}");
        }
    }

    // ===== LLAMADAS A FUNCIONES =====

    private LLVMValueRef VisitFunctionCall(MiniGoCompilerParser.PrimaryExpressionContext context)
    {
        // Obtener el nombre de la función
        string funcName = null;
        if (context.primaryExpression() != null && 
            context.primaryExpression().operand() != null &&
            context.primaryExpression().operand().identifier() != null)
        {
            funcName = context.primaryExpression().operand().identifier().GetText();
        }

        if (string.IsNullOrEmpty(funcName))
        {
            throw new Exception("Invalid function call");
        }

        // Evaluar argumentos
        List<LLVMValueRef> args = new List<LLVMValueRef>();
        if (context.arguments().expressionList() != null)
        {
            foreach (var expr in context.arguments().expressionList().expression())
            {
                var argValue = Visit(expr) as LLVMValueRef?;
                if (argValue.HasValue)
                {
                    args.Add(argValue.Value);
                }
            }
        }

        // Manejar funciones predefinidas
        if (funcName == "print")
        {
            return BuildPrintCall(args, false);
        }
        else if (funcName == "println")
        {
            return BuildPrintCall(args, true);
        }

        // Llamada a función definida por el usuario
        if (functions.ContainsKey(funcName))
        {
            LLVMValueRef funcRef = functions[funcName];
            LLVMTypeRef funcType = functionTypes[funcName];
            return builder.BuildCall2(
                funcType,
                funcRef,
                args.ToArray(),
                "calltmp"
            );
        }

        throw new Exception($"Function not found: {funcName}");
    }

    private LLVMValueRef BuildPrintCall(List<LLVMValueRef> args, bool newline)
    {
        // Para cada argumento, imprimir usando printf
        foreach (var arg in args)
        {
            // Crear el formato string basado en el tipo
            string formatStr = "%d";
            if (arg.TypeOf.Kind == LLVMTypeKind.LLVMPointerTypeKind)
            {
                formatStr = "%s";
            }

            LLVMValueRef formatStrValue = builder.BuildGlobalStringPtr(formatStr, "fmt");

            // Llamar a printf
            builder.BuildCall2(
                printfType,
                printfFunc,
                new[] { formatStrValue, arg },
                ""
            );
        }

        // Si es println, agregar salto de línea
        if (newline)
        {
            LLVMValueRef newlineStr = builder.BuildGlobalStringPtr("\n", "newline");
            builder.BuildCall2(
                printfType,
                printfFunc,
                new[] { newlineStr },
                ""
            );
        }

        // Forzar flush del buffer después de println
        if (newline)
        {
            // fflush(NULL) - flush todos los buffers de salida
            LLVMValueRef nullPtr = LLVMValueRef.CreateConstPointerNull(
                LLVMTypeRef.CreatePointer(LLVMTypeRef.Int8, 0)
            );
            builder.BuildCall2(
                fflushType,
                fflushFunc,
                new[] { nullPtr },
                ""
            );
        }

        // print/println no retornan valor (void), pero necesitamos devolver algo
        // Devolvemos un valor dummy
        return LLVMValueRef.CreateConstInt(int32Type, 0, false);
    }

    private LLVMValueRef VisitLengthExpression(MiniGoCompilerParser.LengthExpressionContext context)
    {
        // len(arr) - obtener el tamaño del array
        var expr = context.expression();

        // Si es un identificador (nombre de array)
        if (expr.primaryExpression() != null &&
            expr.primaryExpression().operand() != null &&
            expr.primaryExpression().operand().identifier() != null)
        {
            string varName = expr.primaryExpression().operand().identifier().GetText();
            LLVMTypeRef varType = ResolveVariableType(varName);

            // Si es un array, devolver su tamaño
            if (varType.Kind == LLVMTypeKind.LLVMArrayTypeKind)
            {
                uint arraySize = varType.ArrayLength;
                return LLVMValueRef.CreateConstInt(int32Type, arraySize, false);
            }

            throw new Exception($"len() can only be used on arrays");
        }

        throw new Exception("Invalid argument to len()");
    }

    // ===== CONTROL DE FLUJO =====

    public override object VisitIfStatement(MiniGoCompilerParser.IfStatementContext context)
    {
        scopes.Push(new Dictionary<string, LLVMValueRef>());
        typeScopes.Push(new Dictionary<string, LLVMTypeRef>());
        
        if (context.simpleStatement() != null)
        {
            Visit(context.simpleStatement());
        }

        var condValue = Visit(context.expression()) as LLVMValueRef?;
        if (!condValue.HasValue) throw new Exception("Invalid condition in if statement");

        LLVMBasicBlockRef thenBlock = currentFunction.AppendBasicBlock("then");
        LLVMBasicBlockRef mergeBlock = currentFunction.AppendBasicBlock("ifcont");
        LLVMBasicBlockRef elseBlock = mergeBlock; 

        bool hasElse = context.ELSE() != null;
        if (hasElse)
        {
            elseBlock = currentFunction.AppendBasicBlock("else");
        }

        builder.BuildCondBr(condValue.Value, thenBlock, elseBlock);

        // then
        builder.PositionAtEnd(thenBlock);
        Visit(context.block(0));
        
        if (thenBlock.Terminator.Handle == IntPtr.Zero)
        {
            builder.BuildBr(mergeBlock);
        }

        // else
        if (hasElse)
        {
            builder.PositionAtEnd(elseBlock);
            
            if (context.ifStatement() != null) Visit(context.ifStatement());
            else if (context.block().Length > 1) Visit(context.block(1));
            
            if (builder.InsertBlock.Terminator.Handle == IntPtr.Zero)
            {
                builder.BuildBr(mergeBlock);
            }
            mergeBlock.MoveAfter(builder.InsertBlock);
        }

        builder.PositionAtEnd(mergeBlock);
        
        scopes.Pop();
        typeScopes.Pop();
        return null;
    }

    public override object VisitLoop(MiniGoCompilerParser.LoopContext context)
    {
        scopes.Push(new Dictionary<string, LLVMValueRef>());
        typeScopes.Push(new Dictionary<string, LLVMTypeRef>());

        if (context.simpleStatement().Length > 0 && context.SEMI().Length > 0)
        {
            Visit(context.simpleStatement(0));
        }

        LLVMBasicBlockRef condBlock = currentFunction.AppendBasicBlock("loopcond");
        LLVMBasicBlockRef bodyBlock = currentFunction.AppendBasicBlock("loopbody");
        LLVMBasicBlockRef postBlock = currentFunction.AppendBasicBlock("looppost");
        LLVMBasicBlockRef endBlock = currentFunction.AppendBasicBlock("loopend");

        builder.BuildBr(condBlock);
        builder.PositionAtEnd(condBlock);

        if (context.expression() != null)
        {
            var condValue = Visit(context.expression()) as LLVMValueRef?;
            if (!condValue.HasValue) throw new Exception("Invalid condition in for loop");
            builder.BuildCondBr(condValue.Value, bodyBlock, endBlock);
        }
        else
        {
            builder.BuildBr(bodyBlock);
        }

        builder.PositionAtEnd(bodyBlock);
        Visit(context.block());
        
        if (builder.InsertBlock.Terminator.Handle == IntPtr.Zero)
        {
            builder.BuildBr(postBlock);
        }

        builder.PositionAtEnd(postBlock);
        if (context.simpleStatement().Length > 1)
        {
            Visit(context.simpleStatement(1));
        }
        else if (context.simpleStatement().Length == 1 && context.SEMI().Length > 0 && context.GetChild(context.ChildCount - 2).GetText() != ";")
        {
             // Caso FOR simpleStatement ; ; simpleStatement { }
             Visit(context.simpleStatement(0));
        }
        builder.BuildBr(condBlock); 

        builder.PositionAtEnd(endBlock);
        
        scopes.Pop();
        typeScopes.Pop();
        return null;
    }
